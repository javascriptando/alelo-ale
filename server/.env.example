# ── Server ────────────────────────────────────────────────
PORT=3333
LOG_LEVEL=info
NODE_ENV=development

# ── Database (PostgreSQL) ─────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/alelo

# ── Redis (BullMQ queues) ─────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Optional override; if empty the app auto-detects the best available model
OPENAI_MODEL=

# ── WhatsApp (Evolution API) ──────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=alelo
# Where Evolution should POST inbound events (this server). Use your public/ngrok
# URL if Evolution runs on another host.
EVOLUTION_WEBHOOK_URL=http://localhost:3333/webhook/whatsapp

# ── DocuSign (eSignature REST API) ────────────────────────
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
DOCUSIGN_OAUTH_BASE=https://account-d.docusign.com
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_PRIVATE_KEY_PATH=./docusign_private.key
DOCUSIGN_WEBHOOK_SECRET=
DOCUSIGN_SIGN_RETURN_URL=https://www.alelo.com.br
PUBLIC_BASE_URL=http://localhost:3333
